# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trader
ADMIN_API_TOKEN=dev-admin-token

# Backpack adapter
# BACKPACK_MODE:
# - mock: use local fixture data
# - live: fetch from Backpack REST
BACKPACK_MODE=mock
BACKPACK_API_BASE_URL=https://api.backpack.exchange
BACKPACK_API_KEY=
# Base64-encoded ED25519 private key / seed used for request signing.
BACKPACK_PRIVATE_KEY=
BACKPACK_WINDOW_MS=5000
BACKPACK_DEFAULT_SYMBOL=BTC_USDC_PERP
BACKPACK_DEFAULT_INTERVAL=1h
BACKPACK_DEFAULT_PRICE_SOURCE=mark
BACKPACK_DEFAULT_MARKET_TYPE=perp
BACKPACK_ACCOUNT_LABEL=backpack-primary

# PostgreSQL
POSTGRES_DB=trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
